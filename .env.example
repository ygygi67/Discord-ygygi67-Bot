# Discord Bot Environment Configuration
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าของคุณ

# =================== Discord Bot Token ===================
# ไปที่ https://discord.com/developers/applications
# สร้าง Bot → Copy Token มาใส่ตรงนี้
DISCORD_TOKEN=your_discord_bot_token_here

# Application ID (จาก Discord Developer Portal)
APPLICATION_ID=your_application_id_here

# Guild ID สำหรับ Sync Commands (คลิกขวาที่เซิร์ฟเวอร์ → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# =================== Database ===================
DATABASE_PATH=data/bot_database.db

# SQL Server Configuration (ถ้าใช้ SQL Server แทน SQLite)
SQL_SERVER_ENABLED=false
SQL_SERVER_HOST=your_server.database.windows.net
SQL_SERVER_DATABASE=DiscordBotDB
SQL_SERVER_USERNAME=your_username
SQL_SERVER_PASSWORD=your_password

# MySQL Configuration (ถ้าใช้ MySQL)
MYSQL_ENABLED=false
MYSQL_HOST=localhost
MYSQL_DATABASE=DiscordBotDB
MYSQL_USERNAME=your_username
MYSQL_PASSWORD=your_password
MYSQL_PORT=3306

# =================== Logging ===================
LOG_LEVEL=INFO

# =================== Distributed Bot System ===================
# โหมดการทำงาน: standalone | master | worker
# standalone = บอทเดี่ยว (แนะนำสำหรับเริ่มต้น)
# master = ควบคุมหลาย shards
# worker = ประมวลผลงานหนัก
BOT_MODE=standalone

# จำนวน Shards (เว้นว่าง = Auto detect)
TOTAL_SHARDS=

# Cluster ID (ถ้ามีหลายเครื่อง: 0, 1, 2...)
CLUSTER_ID=0

# จำนวน Cluster ทั้งหมด
TOTAL_CLUSTERS=1

# จำนวน Workers ในเครื่องนี้
NUM_WORKERS=2

# ไฟล์คิว (แชร์ระหว่างเครื่องได้ถ้าอยู่ใน Network/Cloud drive)
QUEUE_DB_PATH=data/shared_queue.db

# =================== Features ===================
# เปิด/ปิดการกระจายงาน
ENABLE_DISTRIBUTED_MUSIC=true
ENABLE_DISTRIBUTED_STATS=true

# =================== AI / Ollama ===================
# URL ของ Ollama server (ค่าเริ่มต้น: localhost)
OLLAMA_URL=http://localhost:11434/api/generate

# โมเดลที่ใช้ (ต้อง pull ก่อน: ollama pull llama3)
AI_MODEL=llama3

# =================== Youtube Spy ===================
YOUTUBE_SPY_WEBHOOK=your_webhook_url_here
YOUTUBE_SPY_SQL_ENABLE=true
YOUTUBE_SPY_SQL_HOST=your_hosthere
YOUTUBE_SPY_SQL_DB=test
YOUTUBE_SPY_SQL_USER=your_user
YOUTUBE_SPY_SQL_PASSWORD=your_password
YOUTUBE_SPY_SQL_PORT=4000
YOUTUBE_SPY_SQL_TABLE=youtube_log
